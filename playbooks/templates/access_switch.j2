{% if hostname is defined %}
hostname {{ hostname }}
{% endif %}
lldp run
ip domain name ansible-mega-lab.local
spanning-tree mode {{ global_config.spanning_tree_mode }}
{% for user in users %}
username {{ user.username }} privilege {{ user.privilege_level }} secret {{user.password}}
{% endfor %}

{% for vlan in vlans %}
vlan {{vlan.id}}
    name {{ vlan.description }}
{% endfor %}
{% for interface in interfaces %}

interface {{interface.name}}
    description {{interface.description}}
{% if interface.mode is defined and interface.mode == "trunk" %}
    switchport trunk encapsulation dot1q
    switchport mode {{interface.mode}}
    {% if interface.native_vlan is defined %}
    switchport trunk native vlan {{interface.native_vlan}}
    {% endif %}
    {% if interface.allowed_vlans is defined %}
    switchport trunk allowed vlan {{ interface.allowed_vlans }}
    {% endif %}
{% endif %}
{% if interface.mode is defined and interface.mode == "access" %}
    switchport mode access
    {% if interface.access_vlan is defined %}
    switchport access vlan {{ interface.access_vlan }}
    {% endif %}
    {% if interface.portfast is defined and interface.portfast %}
    spanning-tree portfast
    {% endif %}
    {% if interface.bpduguard is defined and interface.bpduguard %}
    spanning-tree bpduguard enable
    {% endif %}
{% endif %}
{% if interface.channel_group is defined %}
    channel-group {{interface.channel_group.id}} mode {{interface.channel_group.mode}}
{% endif%}
{% if interface.ip_address is defined %}
{% if not interface.name.lower().startswith('vlan')%}
    no switchport
    {% endif %}
    ip address {{ interface.ip_address }} {{ interface.mask }}
{% endif %}
{% if interface.shutdown is defined and not interface.shutdown %}
    no shutdown
{% endif %}

{% endfor %}

crypto key generate rsa modulus 2048

ip ssh version 2

line con 0
 logging synchronous
 exec-timeout 0 0

line vty 0 4
 login local
 transport input telnet ssh

service password-encryption
